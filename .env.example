BILLIONMAIL_SMTP_PORT=587
BILLIONMAIL_SMTP_USER=replace_me
BILLIONMAIL_SMTP_PASS=replace_me
BILLIONMAIL_SMTP_FROM=no-reply@smarterbot.store

